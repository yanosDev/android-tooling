<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.YD" parent="Theme.AppCompat.NoActionBar">
        <!-- Background -->
        <item name="android:windowBackground">@color/surface</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- Styles for C24BottomSheetDialogWrapper -->
    <style name="Theme.YD.EdgeToEdgeFloatingDialog" parent="android:Theme.DeviceDefault.Dialog">
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowClipToOutline">false</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowElevation">0dp</item>
    </style>

    <!-- Theme for C24BottomSheetDialogWrapper -->
    <style name="Theme.YD.EdgeToEdgeFloatingDialogWindow">
        <item name="android:dialogTheme">@style/Theme.YD.EdgeToEdgeFloatingDialog</item>
    </style>
</resources>